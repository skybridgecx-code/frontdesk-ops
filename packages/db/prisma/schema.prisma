generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum BusinessVertical {
  HVAC
  PLUMBING
  ELECTRICAL
  ROOFING
  OTHER
}

enum PhoneNumberProvider {
  TWILIO
  OTHER
}

enum AgentChannel {
  VOICE
  SMS
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PhoneRoutingMode {
  AI_ALWAYS
  AI_AFTER_HOURS
  HUMAN_ONLY
  AI_OVERFLOW
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELED
}

enum CallRouteKind {
  AI
  HUMAN
  VOICEMAIL
  REJECTED
}

enum CallTriageStatus {
  OPEN
  CONTACTED
  ARCHIVED
}

enum CallReviewStatus {
  UNREVIEWED
  REVIEWED
  NEEDS_REVIEW
}

enum ProspectStatus {
  NEW
  READY
  IN_PROGRESS
  ATTEMPTED
  RESPONDED
  QUALIFIED
  DISQUALIFIED
  ARCHIVED
}

enum ProspectPriority {
  HIGH
  MEDIUM
  LOW
}

enum ProspectSourceProvider {
  MANUAL
  PUBLIC_INTAKE
  GOOGLE_PLACES
  APOLLO_PEOPLE_SEARCH
}

enum ProspectAttemptChannel {
  CALL
  EMAIL
  SMS
}

enum ProspectAttemptOutcome {
  NO_ANSWER
  LEFT_VOICEMAIL
  SENT_EMAIL
  REPLIED
  BAD_FIT
  DO_NOT_CONTACT
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  businesses    Business[]
  phoneNumbers  PhoneNumber[]
  agentProfiles AgentProfile[]
  calls         Call[]
  prospects     Prospect[]
  prospectImportBatches ProspectImportBatch[]
  subscription  Subscription?
  tenantUsers   TenantUser[]

  @@index([slug])
}

model Subscription {
  id                   String   @id @default(uuid())
  tenantId             String   @unique
  stripeCustomerId     String
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([stripeCustomerId])
}

model TenantUser {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  tenantId    String
  role        String   @default("owner")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([clerkUserId])
  @@index([tenantId])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  fullName     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships  Membership[]

  @@index([email])
}

model Membership {
  id           String         @id @default(cuid())
  tenantId     String
  userId       String
  role         MembershipRole @default(MEMBER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Business {
  id             String            @id @default(cuid())
  tenantId       String
  name           String
  legalName      String?
  slug           String
  vertical       BusinessVertical  @default(OTHER)
  websiteUrl     String?
  timezone       String            @default("America/New_York")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locations      Location[]
  phoneNumbers   PhoneNumber[]
  agentProfiles  AgentProfile[]
  businessHours  BusinessHours[]
  serviceAreas   ServiceArea[]
  calls          Call[]
  prospects      Prospect[]
  prospectImportBatches ProspectImportBatch[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Location {
  id             String       @id @default(cuid())
  businessId     String
  name           String
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  countryCode    String?      @default("US")
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumbers   PhoneNumber[]

  @@index([businessId])
}

model PhoneNumber {
  id                       String              @id @default(cuid())
  tenantId                 String
  businessId               String
  locationId               String?
  provider                 PhoneNumberProvider @default(TWILIO)
  externalSid              String?
  e164                     String              @unique
  label                    String?
  isActive                 Boolean             @default(true)
  routingMode              PhoneRoutingMode    @default(AI_ALWAYS)
  primaryAgentProfileId    String?
  afterHoursAgentProfileId String?
  enableMissedCallTextBack Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  tenant                   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                 Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location                 Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  primaryAgentProfile      AgentProfile?       @relation("PhoneNumberPrimaryAgent", fields: [primaryAgentProfileId], references: [id], onDelete: SetNull)
  afterHoursAgentProfile   AgentProfile?       @relation("PhoneNumberAfterHoursAgent", fields: [afterHoursAgentProfileId], references: [id], onDelete: SetNull)
  calls                    Call[]

  @@index([tenantId])
  @@index([businessId])
  @@index([locationId])
  @@index([externalSid])
  @@index([primaryAgentProfileId])
  @@index([afterHoursAgentProfileId])
}

model AgentProfile {
  id                        String        @id @default(cuid())
  tenantId                  String
  businessId                String
  name                      String
  channel                   AgentChannel  @default(VOICE)
  language                  String        @default("en")
  voiceName                 String?
  systemPrompt              String?
  isActive                  Boolean       @default(true)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  tenant                    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  primaryForPhoneNumbers    PhoneNumber[] @relation("PhoneNumberPrimaryAgent")
  afterHoursForPhoneNumbers PhoneNumber[] @relation("PhoneNumberAfterHoursAgent")
  calls                     Call[]

  @@index([tenantId])
  @@index([businessId])
}

model BusinessHours {
  id              String    @id @default(cuid())
  businessId      String
  weekday         Weekday
  openTime        String?
  closeTime       String?
  isClosed        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, weekday])
  @@index([businessId])
}

model ServiceArea {
  id              String    @id @default(cuid())
  businessId      String
  label           String
  city            String?
  state           String?
  postalCode      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([city, state])
  @@index([postalCode])
}


model Call {
  id                String         @id @default(cuid())
  tenantId          String
  businessId        String
  phoneNumberId     String
  agentProfileId    String?
  twilioCallSid     String         @unique
  twilioStreamSid   String?        @unique
  direction         CallDirection  @default(INBOUND)
  status            CallStatus     @default(RINGING)
  routeKind         CallRouteKind?
  fromE164          String?
  toE164            String?
  callerTranscript    String?
  assistantTranscript String?
  leadName           String?
  leadPhone          String?
  leadIntent         String?
  urgency            String?
  serviceAddress     String?
  summary            String?
  operatorNotes      String?
  triageStatus       CallTriageStatus @default(OPEN)
  reviewStatus       CallReviewStatus @default(UNREVIEWED)
  contactedAt        DateTime?
  archivedAt         DateTime?
  reviewedAt         DateTime?
  startedAt          DateTime       @default(now())
  answeredAt        DateTime?
  endedAt           DateTime?
  durationSeconds   Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business          Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumber       PhoneNumber    @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  agentProfile      AgentProfile?  @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)
  events            CallEvent[]

  @@index([tenantId])
  @@index([businessId])
  @@index([phoneNumberId])
  @@index([agentProfileId])
  @@index([twilioCallSid])
  @@index([twilioStreamSid])
  @@index([status])
  @@index([triageStatus])
  @@index([reviewStatus])
  @@index([fromE164])
  @@index([routeKind])
}

model CallEvent {
  id                String      @id @default(cuid())
  callId            String
  type              String
  sequence          Int
  payloadJson       Json?
  createdAt         DateTime    @default(now())

  call              Call        @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, sequence])
  @@index([callId])
  @@index([type])
}

model Prospect {
  id              String            @id @default(cuid())
  tenantId        String
  businessId      String
  prospectSid     String            @unique
  companyName     String
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  normalizedPhone String?
  normalizedEmail String?
  city            String?
  state           String?
  sourceLabel     String?
  sourceProvider  ProspectSourceProvider @default(MANUAL)
  sourceProviderRecordId String?
  sourceFingerprint String?
  sourceWebsiteUrl String?
  sourceMapsUrl   String?
  sourceLinkedinUrl String?
  sourceCategory  String?
  sourceRoleTitle String?
  sourceMetadataJson Json?
  lastImportBatchId String?
  firstSeenAt     DateTime          @default(now())
  lastSeenAt      DateTime          @default(now())
  serviceInterest String?
  notes           String?
  status          ProspectStatus    @default(NEW)
  priority        ProspectPriority?
  nextActionAt    DateTime?
  lastAttemptAt   DateTime?
  respondedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lastImportBatch ProspectImportBatch? @relation(fields: [lastImportBatchId], references: [id], onDelete: SetNull)
  attempts        ProspectAttempt[]

  @@index([tenantId])
  @@index([businessId])
  @@index([sourceProvider])
  @@index([lastImportBatchId])
  @@index([status])
  @@index([priority])
  @@index([nextActionAt])
  @@index([lastAttemptAt])
  @@index([companyName])
  @@unique([tenantId, businessId, normalizedEmail])
  @@unique([tenantId, businessId, normalizedPhone])
  @@unique([tenantId, businessId, sourceProvider, sourceProviderRecordId])
  @@unique([tenantId, businessId, sourceProvider, sourceFingerprint])
}

model ProspectAttempt {
  id          String                @id @default(cuid())
  prospectId  String
  channel     ProspectAttemptChannel
  outcome     ProspectAttemptOutcome
  note        String?
  attemptedAt DateTime              @default(now())
  createdAt   DateTime              @default(now())

  prospect    Prospect              @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([channel])
  @@index([outcome])
  @@index([attemptedAt])
}

model ProspectImportBatch {
  id            String                 @id @default(cuid())
  tenantId      String
  businessId    String
  sourceProvider ProspectSourceProvider
  sourceLabel   String?
  createdCount  Int                    @default(0)
  updatedCount  Int                    @default(0)
  skippedCount  Int                    @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  prospects     Prospect[]

  @@index([tenantId])
  @@index([businessId])
  @@index([sourceProvider])
  @@index([createdAt])
}
