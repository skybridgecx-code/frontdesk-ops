generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum BusinessVertical {
  HVAC
  PLUMBING
  ELECTRICAL
  ROOFING
  OTHER
}

enum PhoneNumberProvider {
  TWILIO
  OTHER
}

enum AgentChannel {
  VOICE
  SMS
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PhoneRoutingMode {
  AI_ALWAYS
  AI_AFTER_HOURS
  HUMAN_ONLY
  AI_OVERFLOW
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  CANCELED
}

enum CallRouteKind {
  AI
  HUMAN
  VOICEMAIL
  REJECTED
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  businesses    Business[]
  phoneNumbers  PhoneNumber[]
  agentProfiles AgentProfile[]
  calls         Call[]

  @@index([slug])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  fullName     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  memberships  Membership[]

  @@index([email])
}

model Membership {
  id           String         @id @default(cuid())
  tenantId     String
  userId       String
  role         MembershipRole @default(MEMBER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

model Business {
  id             String            @id @default(cuid())
  tenantId       String
  name           String
  legalName      String?
  slug           String
  vertical       BusinessVertical  @default(OTHER)
  websiteUrl     String?
  timezone       String            @default("America/New_York")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  locations      Location[]
  phoneNumbers   PhoneNumber[]
  agentProfiles  AgentProfile[]
  businessHours  BusinessHours[]
  serviceAreas   ServiceArea[]
  calls          Call[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Location {
  id             String       @id @default(cuid())
  businessId     String
  name           String
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  countryCode    String?      @default("US")
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumbers   PhoneNumber[]

  @@index([businessId])
}

model PhoneNumber {
  id                       String              @id @default(cuid())
  tenantId                 String
  businessId               String
  locationId               String?
  provider                 PhoneNumberProvider @default(TWILIO)
  externalSid              String?
  e164                     String              @unique
  label                    String?
  isActive                 Boolean             @default(true)
  routingMode              PhoneRoutingMode    @default(AI_ALWAYS)
  primaryAgentProfileId    String?
  afterHoursAgentProfileId String?
  enableMissedCallTextBack Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  tenant                   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                 Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location                 Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  primaryAgentProfile      AgentProfile?       @relation("PhoneNumberPrimaryAgent", fields: [primaryAgentProfileId], references: [id], onDelete: SetNull)
  afterHoursAgentProfile   AgentProfile?       @relation("PhoneNumberAfterHoursAgent", fields: [afterHoursAgentProfileId], references: [id], onDelete: SetNull)
  calls                    Call[]

  @@index([tenantId])
  @@index([businessId])
  @@index([locationId])
  @@index([externalSid])
  @@index([primaryAgentProfileId])
  @@index([afterHoursAgentProfileId])
}

model AgentProfile {
  id                        String        @id @default(cuid())
  tenantId                  String
  businessId                String
  name                      String
  channel                   AgentChannel  @default(VOICE)
  language                  String        @default("en")
  voiceName                 String?
  systemPrompt              String?
  isActive                  Boolean       @default(true)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  tenant                    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business                  Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  primaryForPhoneNumbers    PhoneNumber[] @relation("PhoneNumberPrimaryAgent")
  afterHoursForPhoneNumbers PhoneNumber[] @relation("PhoneNumberAfterHoursAgent")
  calls                     Call[]

  @@index([tenantId])
  @@index([businessId])
}

model BusinessHours {
  id              String    @id @default(cuid())
  businessId      String
  weekday         Weekday
  openTime        String?
  closeTime       String?
  isClosed        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, weekday])
  @@index([businessId])
}

model ServiceArea {
  id              String    @id @default(cuid())
  businessId      String
  label           String
  city            String?
  state           String?
  postalCode      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([city, state])
  @@index([postalCode])
}


model Call {
  id                String         @id @default(cuid())
  tenantId          String
  businessId        String
  phoneNumberId     String
  agentProfileId    String?
  twilioCallSid     String         @unique
  twilioStreamSid   String?        @unique
  direction         CallDirection  @default(INBOUND)
  status            CallStatus     @default(RINGING)
  routeKind         CallRouteKind?
  fromE164          String?
  toE164            String?
  callerTranscript    String?
  assistantTranscript String?
  leadName           String?
  leadPhone          String?
  leadIntent         String?
  urgency            String?
  serviceAddress     String?
  summary            String?
  startedAt          DateTime       @default(now())
  answeredAt        DateTime?
  endedAt           DateTime?
  durationSeconds   Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  business          Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phoneNumber       PhoneNumber    @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  agentProfile      AgentProfile?  @relation(fields: [agentProfileId], references: [id], onDelete: SetNull)
  events            CallEvent[]

  @@index([tenantId])
  @@index([businessId])
  @@index([phoneNumberId])
  @@index([agentProfileId])
  @@index([twilioCallSid])
  @@index([twilioStreamSid])
  @@index([status])
  @@index([routeKind])
}

model CallEvent {
  id                String      @id @default(cuid())
  callId            String
  type              String
  sequence          Int
  payloadJson       Json?
  createdAt         DateTime    @default(now())

  call              Call        @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, sequence])
  @@index([callId])
  @@index([type])
}
